```gitignore
###############################################################################
# J.A.R.V.I.S. - Git Ignore
# Version: 0.1
###############################################################################

############################
# Python
############################
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.dll
*.dylib

############################
# Virtual Environments
############################
.venv/
venv/
env/
ENV/

############################
# IDEs
############################
.vscode/
.idea/

############################
# Operating Systems
############################
.DS_Store
Thumbs.db
desktop.ini
.AppleDouble
.LSOverride
ehthumbs.db
*~

############################
# Environment Variables
############################
.env
.env.*
!.env.example

############################
# Python Cache
############################
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.cache/
.tox/
.nox/

############################
# Coverage
############################
.coverage
.coverage.*
coverage.xml
htmlcov/

############################
# Build
############################
build/
dist/
site/
pip-wheel-metadata/
*.egg
*.egg-info/
.eggs/

############################
# Runtime
############################
*.pid
*.lock

############################
# Logs
############################
storage/logs/
*.log

############################
# Databases
############################
*.db
*.sqlite
*.sqlite3
*.db-journal

############################
# Storage
############################
storage/cache/
storage/temp/
storage/uploads/
storage/backups/

############################
# AI / Machine Learning
############################
models/
weights/
embeddings/
vector_store/
chroma/
qdrant/
ollama_models/
whisper_models/
*.gguf

############################
# Node.js
############################
node_modules/

############################
# React / Next.js
############################
.next/
out/

############################
# Docker
############################
docker-compose.override.yml

############################
# Certificates & Secrets
############################
*.pem
*.key
*.crt

secrets/
credentials/
service_account.json

############################
# Temporary Files
############################
tmp/
temp/
*.tmp
*.bak
*.backup

############################
# Jupyter
############################
.ipynb_checkpoints/

############################
# FastAPI
############################
instance/

############################
# User Data
############################
user_data/

############################
# Local Configuration
############################
config.local.yaml
config.local.yml
config.local.json

###############################################################################
# END
###############################################################################
```
